<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean class="com.prerna.Address" id="adrId">
    <property name="houseno" value="123"/>
    <property name="city" value="Jaipur"/>
    <property name="pincode" value="303012"/>    
    </bean>
    
    <bean class="com.prerna.Student" id="stdId">
    <property name="name" value="Prerna"/>
    <property name="rollno" value="5"/>  
    <property name="adress" ref="adrId"></property> 
    </bean>
</beans>